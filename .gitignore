.claude/settings.json

# 依存関係
node_modules/

# Next.js ビルド成果物
.next/
out/
dist/

# 環境変数（実値を含むファイルはコミットしない）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel ローカル設定
.vercel/

# エディタ固有ファイル
.DS_Store
.idea/
*.swp
*.swo
.vscode/

# TypeScript ビルドキャッシュ
tsconfig.tsbuildinfo
*.tsbuildinfo

# テスト成果物
coverage/

# npm install 時に生成される WASM バイナリ（prepare スクリプトで public/ にコピーされる）
public/resvg.wasm

# フォント（public/fonts/OGSansJP-*.otf）は意図的にコミットしている。
# git 管理外にすると Vercel の git 連携デプロイに含まれず実行時に読めなくなるため。
# scripts/subset-fonts.sh でサブセット生成した約2.3MB の成果物。
