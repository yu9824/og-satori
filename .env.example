# og-satori 環境変数サンプル
# このファイルをコピーして .env.local を作成し、必要な値を設定してください。
# cp .env.example .env.local
#
# すべての変数はオプションです。コメントアウトのままでもデフォルト値で動作します。

# ────────────────────────────────────────────────
# アプリケーション設定
# ────────────────────────────────────────────────

# ブログ名: OGP テンプレートの固定要素として表示される
# デフォルト: yu9824's Notes
# SITE_NAME="yu9824's Notes"

# ────────────────────────────────────────────────
# 画像デフォルト寸法
# ────────────────────────────────────────────────

# デフォルト画像幅（px）
# デフォルト: 1200（OGP 標準サイズ）
# DEFAULT_WIDTH=1200

# デフォルト画像高さ（px）
# デフォルト: 630（OGP 標準サイズ）
# DEFAULT_HEIGHT=630

# テキスト描画エリアの幅比率（0〜1）
# デフォルト: 0.8（画像幅の 80%）
# DEFAULT_TEXT_WIDTH_RATIO=0.8
