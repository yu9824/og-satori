# og-satori 環境変数サンプル
# このファイルをコピーして .env.local を作成し、実際の値を設定してください。
# cp .env.example .env.local

# ────────────────────────────────────────────────
# アプリケーション設定
# ────────────────────────────────────────────────

# ブログ名: OGP テンプレートの固定要素として表示される
# デフォルト: yu9824's Notes
SITE_NAME="yu9824's Notes"

# サービスのベース URL
# Vercel にデプロイした場合は自動的に設定されるため、通常は不要
# NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# ────────────────────────────────────────────────
# フォント設定
# ────────────────────────────────────────────────

# Regular ウェイトフォントの URL
# デフォルト: {baseUrl}/fonts/NotoSansJP-Regular.otf（同梱サブセット）
# カスタムフォントを使う場合はここに URL を指定する
# FONT_URL_REGULAR=https://cdn.example.com/fonts/MyFont-Regular.otf

# Bold ウェイトフォントの URL
# デフォルト: {baseUrl}/fonts/NotoSansJP-Bold.otf（同梱サブセット）
# FONT_URL_BOLD=https://cdn.example.com/fonts/MyFont-Bold.otf

# フォントフェッチのタイムアウト（ミリ秒）
# デフォルト: 5000
# FONT_FETCH_TIMEOUT_MS=5000

# ────────────────────────────────────────────────
# 画像デフォルト寸法
# ────────────────────────────────────────────────

# デフォルト画像幅（px）
# デフォルト: 1200（OGP 標準サイズ）
# DEFAULT_WIDTH=1200

# デフォルト画像高さ（px）
# デフォルト: 630（OGP 標準サイズ）
# DEFAULT_HEIGHT=630

# テキスト描画エリアの幅比率（0〜1）
# デフォルト: 0.8（画像幅の 80%）
# DEFAULT_TEXT_WIDTH_RATIO=0.8
